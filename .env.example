# Copia este archivo como ".env" y completa con tus datos.
# (En Railway/Render esto va en la pestaña "Variables", NO en un archivo.)

# ─────────────────────────── TWILIO (WhatsApp) ───────────────────────────
TWILIO_ACCOUNT_SID=tu_account_sid_aqui
TWILIO_AUTH_TOKEN=tu_auth_token_aqui

# Número de WhatsApp de Twilio (sandbox o producción), formato E.164.
# OJO: necesario para el "saludo diferido" (responder unos segundos después,
# para que se sienta humano).
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Retraso del saludo de apertura: aleatorio entre MIN y MAX (milisegundos),
# para que NO parezca un bot que responde en 0 segundos.
# Pon SALUDO_DELAY_MAX_MS=0 para desactivar y saludar al instante.
SALUDO_DELAY_MIN_MS=20000
SALUDO_DELAY_MAX_MS=45000

# Puerto del servidor (Railway/Render lo asignan automáticamente)
PORT=3000

# ─────────────── LLM para la conversación (tono humano) ───────────────
# Funciona con OpenAI o con DeepSeek (compatible con el mismo SDK).
#
# OPCIÓN A · OpenAI:
#   OPENAI_API_KEY=sk-tu_key_de_openai   (https://platform.openai.com/api-keys)
#   OPENAI_MODEL=gpt-4o-mini
#   (deja OPENAI_BASE_URL vacío)
#
# OPCIÓN B · DeepSeek (más económico, recomendado si tienes volumen):
#   OPENAI_API_KEY=sk-tu_key_de_deepseek (https://platform.deepseek.com)
#   OPENAI_BASE_URL=https://api.deepseek.com
#   OPENAI_MODEL=deepseek-v4-flash
#
# ⚠️ NO pongas aquí tu key real. Este archivo se sube a GitHub.
#    Tu key real va SOLO en el .env (ignorado por git) o en las Variables del host.
OPENAI_API_KEY=sk-tu_api_key_aqui
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.deepseek.com

# ─────────────────────── LINKS DE CIERRE (las 2 ramas) ───────────────────────
# Rama CALIFICADA (>= $1,000 USD): link de Calendly para agendar la llamada.
BOOKING_LINK=https://calendly.com/d/cxz9-jk3-tfp/e-master-brayan-hernandez

# Rama CLUB (< $1,000 USD): link del club Upgrade Project en Skool ($34/mes).
CLUB_LINK=https://www.skool.com/upgrade-project-6844/about

# ─────────────────────── CAPTURA DE LEADS (opcional) ───────────────────────
# Si configuras una URL (Google Apps Script, Make, Zapier, n8n, tu CRM...),
# cada vez que alguien agenda, el bot le hace POST con los datos del lead.
# Déjala vacía para solo registrar el lead en los logs.
# LEAD_WEBHOOK_URL=https://script.google.com/macros/s/XXXX/exec
