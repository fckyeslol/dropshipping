# Copia este archivo como ".env" y completa con tus datos.
# (En Railway/Render esto va en la pestaña "Variables", NO en un archivo.)

# ─────────────────────────── TWILIO (WhatsApp) ───────────────────────────
TWILIO_ACCOUNT_SID=tu_account_sid_aqui
TWILIO_AUTH_TOKEN=tu_auth_token_aqui

# Número de WhatsApp de Twilio (sandbox o producción), formato E.164.
# OJO: necesario para el "saludo diferido" (responder unos segundos después,
# para que se sienta humano).
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Retraso del saludo de apertura: aleatorio entre MIN y MAX (milisegundos),
# para que NO parezca un bot que responde en 0 segundos.
# Pon SALUDO_DELAY_MAX_MS=0 para desactivar y saludar al instante.
SALUDO_DELAY_MIN_MS=20000
SALUDO_DELAY_MAX_MS=45000

# Puerto del servidor (Railway/Render lo asignan automáticamente)
PORT=3000

# ─────────────── LLM para la conversación (tono humano) ───────────────
# Funciona con OpenAI o con DeepSeek (compatible con el mismo SDK).
#
# OPCIÓN A · OpenAI:
#   OPENAI_API_KEY=sk-tu_key_de_openai   (https://platform.openai.com/api-keys)
#   OPENAI_MODEL=gpt-4o-mini
#   (deja OPENAI_BASE_URL vacío)
#
# OPCIÓN B · DeepSeek (más económico, recomendado si tienes volumen):
#   OPENAI_API_KEY=sk-tu_key_de_deepseek (https://platform.deepseek.com)
#   OPENAI_BASE_URL=https://api.deepseek.com
#   OPENAI_MODEL=deepseek-v4-flash
#
# ⚠️ NO pongas aquí tu key real. Este archivo se sube a GitHub.
#    Tu key real va SOLO en el .env (ignorado por git) o en las Variables del host.
OPENAI_API_KEY=sk-tu_api_key_aqui
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.deepseek.com

# ─────────────────────── LINKS DE CIERRE (las 2 ramas) ───────────────────────
# Rama CALIFICADA (>= $1,000 USD): link de Calendly para agendar la llamada.
BOOKING_LINK=https://calendly.com/d/cxz9-jk3-tfp/e-master-brayan-hernandez

# Rama CLUB (< $1,000 USD): link del club Upgrade Project en Skool ($34/mes).
CLUB_LINK=https://www.skool.com/upgrade-project-6844/about

# ──────────────── TABLA DEL SERVICIO 1:1 (solo los que AGENDAN llamada) ────────────────
# URL (Google Apps Script, Make, Zapier, n8n...) que recibe SOLO los leads que
# agendan la llamada (rama "llamada"), con nombre, teléfono, rama, ocupación y capital.
# El club NO se manda aquí. Déjala vacía para solo verlos en los logs.
# LEAD_WEBHOOK_URL=https://script.google.com/macros/s/XXXX/exec

# ──────────────── SEGUIMIENTO (re-contacto de quien NO agenda) ────────────────
# URL que recibe el PRIMER contacto de cada persona (estado "sin_agendar") y
# luego su conversión (estado "agendo"/"club"). Tu automatización (Make/Zapier)
# usa esto para mandar el re-contacto a las 24h a quien quedó "sin_agendar".
# (El envío proactivo a 24h requiere PLANTILLAS aprobadas por Meta — ver README.)
# SEGUIMIENTO_WEBHOOK_URL=https://hook.make.com/XXXX

# ──────────────── AUDIO DEL SALUDO (opcional) ────────────────
# Audio pregrabado que pide el nombre. Si lo defines, el saludo se manda como
# audio en vez de texto. Sube tu archivo a /public (ej. public/saludo.ogg) y pon:
# SALUDO_AUDIO_URL=https://dropshipping-production-2fb2.up.railway.app/saludo.ogg
# (Para que se vea como nota de voz, usa formato .ogg/opus.)
# SALUDO_AUDIO_URL=

# ──────────────── VIDEO TARJETA NEQUI (opcional, rama club / Colombia) ────────────────
# Link del video de "cómo sacar la tarjeta Nequi" para quien no tiene tarjeta y quiere
# entrar al club. Si lo defines, el bot lo comparte cuando aplica.
# NEQUI_VIDEO_URL=https://...

# ──────────────── VIDEO GRATIS (off-ramp: NO tiene dinero ni para el club) ────────────────
# Si la persona deja claro que no tiene nada de dinero, el bot le manda este video gratis
# y lo invita a seguir el canal, en vez de insistir.
# VIDEO_GRATIS_URL=https://youtu.be/...
